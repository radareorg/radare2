prefix=@PREFIX@
exec_prefix=${prefix}
libdir=@LIBDIR@
includedir=${prefix}/include

Name: r_asm
Description: radare foundation libraries
Version: @VERSION@
Requires: r_util r_reg r_syscall r_search r_cons r_flag r_muta r_arch r_esil
Libs: -L${libdir} -lr_asm  
Libs.private: -lr_shlr
Cflags: -I${includedir}/libr 
