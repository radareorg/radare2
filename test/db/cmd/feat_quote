NAME=Quotes and substitution
CMDS=<<EOF
w "Hello $(?e World)"
ps
w0 15
w 'Hello $(?e World)'
ps
w0 15
w "Hello \$(?e World)"
ps
w0 17
w 'Hello \`?e World\`'
ps
w0 17
EOF
EXPECT=<<EOF
Hello World
Hello $(?e World)
Hello $(?e World)
Hello `?e World`
EOF
RUN

NAME=Quote-aware command substitutions
CMDS=<<EOF
w "Hello `?e World`"
ps
w0 64
w 'Hello `?e World`'
ps
w0 64
w "A$(?en B$(?en C))D"
ps
w0 64
w "$(?e ')')"
ps
w0 64
w "safe:$(?e:Ijs/ZSBJTkpFQ1QgJCg/ZSBORVNURUQpIGA/ZSBUSUNLYA==)"
ps
w0 64
w "plain:$(?e:JGZvbw==)"
ps
w0 64
w 'literal:"$(?e NO)"'
ps
EOF
EXPECT=<<EOF
Hello World
Hello `?e World`
ABCD
)
safe:";?e INJECT $(?e NESTED) `?e TICK`
plain:$foo
literal:"$(?e NO)"
EOF
RUN

NAME=Escaped operator parity
CMDS=<<EOF
echo literal\;?e NOT_RUN
echo active\\;?e SECOND
echo literal\|E
echo active\\|E
echo literal\>$a
echo active\\>$a
cat $a
echo literal\$(?e NOT_RUN)
echo active\\$(?en OK)
echo literal\`?e NOT_RUN\`
echo active\\`?en OK`
echo \# \@ \~ \! \& \* \( \) \< \> \$
echo mixed\;literal;?e SECOND_MIXED
echo mixed\|literal|E
echo mixed\>literal >$b
cat $b
EOF
EXPECT=<<EOF
literal;?e NOT_RUN
active\
SECOND
literal|E
YWN0aXZlXAo=
literal>$a
active\
literal$(?e NOT_RUN)
active\OK
literal`?e NOT_RUN`
active\OK
# @ ~ ! & * ( ) < > $
mixed;literal
SECOND_MIXED
bWl4ZWR8bGl0ZXJhbAo=
mixed>literal
EOF
RUN

NAME=Escaped quote parity
CMDS=<<EOF
echo 'pa\'tata'
echo "pa\"tata"
echo 'pa\\tata'
echo "pa\\tata"
echo 'safe\';?e NOT_RUN'
echo "safe\";?e NOT_RUN"
EOF
EXPECT=<<EOF
pa'tata
pa"tata
pa\tata
pa\tata
safe';?e NOT_RUN
safe";?e NOT_RUN
EOF
RUN

NAME=Even backslashes do not escape a single quote
CMDS=<<EOF
echo 'pa\\'tata'
EOF
EXPECT_ERR=<<EOF
ERROR: Unterminated single quote
EOF
RUN

NAME=Even backslashes do not escape a double quote
CMDS=<<EOF
echo "pa\\"tata"
EOF
EXPECT_ERR=<<EOF
ERROR: Unterminated double quote
EOF
RUN

