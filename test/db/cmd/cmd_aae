NAME=aae clears call-clobbered regs before xref inference
FILE=malloc://0x400
ARGS=-w -a x86 -b 64
CMDS=<<EOF
s 0x100
wx 48c7c080010000e814000000488d18c3
s 0x120
wx c3
s 0x100
e anal.cc=amd64
e anal.cc.clobber=false
aae 0x10
axq~0x00000180
?e --
ax-*
s 0x100
e anal.cc.clobber=true
aae 0x10
axq~0x00000180
?e --
e anal.cc.clobber
e asm.cmt.reguse
EOF
EXPECT=<<EOF
0x0000010c -> 0x00000180  STRN:r--
--
--
true
false
EOF
RUN

