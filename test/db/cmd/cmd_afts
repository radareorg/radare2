NAME=afts synthesizes struct from pointer-argument accesses
FILE=malloc://256
ARGS=-a x86 -b 64
CMDS=<<EOF
wx 8b078b4f088b571001c801d0c3
af
afts
EOF
EXPECT=<<EOF
struct fcn_00000000_arg0 {
  uint32_t field_0x0;
  uint8_t pad_0x4[4]; // gap
  uint32_t field_0x8;
  uint8_t pad_0xc[4]; // gap
  uint32_t field_0x10;
};
EOF
RUN

