NAME=newprj multiple flags and spaces
FILE=malloc://0x1000
CMDS=<<EOF
mkdir .tmp
rm -f .tmp/newprj-multi.prj
fs+alpha
f a.one=0x100
f a.two=0x110
fs+beta
f b.one=0x200
fs *
f loose=0x300
prj save .tmp/newprj-multi.prj > /dev/null
f-*
fs-*
prj load .tmp/newprj-multi.prj > /dev/null
fs alpha
f~a.
fs beta
f~b.
fs *
fd 0x300
rm .tmp/newprj-multi.prj
EOF
EXPECT=<<EOF
0x00000100 1 a.one
0x00000110 1 a.two
0x00000200 1 b.one
loose
EOF
