NAME=pdct region ast if-else diamond
FILE=malloc://64
ARGS=-a x86 -b 64
CMDS=<<EOF
wx 83ff01 7507 b801000000 eb05 b802000000 c3 @ 0
af @ 0
pdct
EOF
EXPECT=<<EOF
seq 0x00000000
  if-else 0x00000000
    bb 0x0000000c
    bb 0x00000005
  bb 0x00000011
EOF
RUN

