NAME=visual_dw
FILE=-
CMDS=<<EOF
Vc10dwq @e:scr.interactive=true > /dev/null
pd 20~dword?
EOF
EXPECT=<<EOF
10
EOF
RUN

NAME=Vc+cq
FILE=-
CMDS=<<EOF
e scr.interactive=true
Vc+cq
p8 1
EOF
EXPECT=<<EOF
01
EOF
RUN

NAME=visual hex scroll
FILE=-
CMDS=<<EOF
e scr.interactive=true
e asm.arch=x86
e asm.bits=64
wx 4889e54889e5
Vjq
s
EOF
EXPECT=<<EOF
0x10
EOF
RUN

NAME=visual op scroll
FILE=-
CMDS=<<EOF
e asm.arch=x86
e asm.bits=64
e scr.interactive=true
wx 4889e54889e5
Vpjq
s
EOF
EXPECT=<<EOF
0x3
EOF
RUN

NAME=visual arm64 op scroll up aligns
FILE=-
ARGS=-a arm -b 64
CMDS=<<EOF
e scr.interactive=true
e arch.codealign=4
s 7
Vpkq
s
EOF
EXPECT=<<EOF
0x0
EOF
RUN

NAME=visual cmd.visual disasm scroll aligns
FILE=-
ARGS=-a arm -b 64
CMDS=<<EOF
e scr.interactive=true
e arch.codealign=4
e cmd.visual=pd 8
s 1
Vjq
s
EOF
EXPECT=<<EOF
0x4
EOF
RUN

NAME=visual string meta scroll up rows
FILE=-
CMDS=<<EOF
e scr.interactive=true
e asm.arch=x86
e asm.bits=64
e asm.hints=false
e hex.cols=16
wx 909090909090909090909090909090909090909090909090909090909090909090909090909090909090909090909090
Cs 32 @ 0x10
s 0x20
Vpkq
s
s 0x30
Vpkq
s
EOF
EXPECT=<<EOF
0x10
0x20
EOF
RUN

NAME=visual hex pP scroll
FILE=-
CMDS=<<EOF
e asm.arch=x86
e asm.bits=64
e scr.interactive=true
wx 4889e54889e5
VpPjq
s
EOF
EXPECT=<<EOF
0x10
EOF
RUN

NAME=visual noninteractive
FILE=-
CMDS=<<EOF
e scr.interactive=false
V
v
EOF
EXPECT_ERR=<<EOF
ERROR: Visual mode requires scr.interactive=true
ERROR: Panel mode requires scr.interactive=true
EOF
RUN
