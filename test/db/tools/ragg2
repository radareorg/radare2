.equ printf, 0x1fa0b4

.global main
main:
  push {fp,lr}
  add fp, sp, 4
  sub sp, sp, 32
# rcc_fun 1 (printf)
# encode filtered string (fnord\n) (printf)
  adr r0, 4
  b 12
.string "fnord\n"
.fill 1, 1, 0
  str r0, [sp, 4]
