NAME=jni types auto-load arm64
FILE=bins/elf/jni/jniO0-arm64
CMDS=<<EOF
e asm.os=android
tk jboolean
tk jstring
tk JNIEnv
tk JNINativeInterface
EOF
EXPECT=<<EOF
typedef
typedef
typedef
struct
EOF
RUN

