EOF
EXPECT=<<EOF
EOF
RUN

NAME=jni jobjectRefType enum
FILE=bins/elf/jni/jniO0-arm64
CMDS=<<EOF
e asm.os=android
te jobjectRefType
EOF
EXPECT=<<EOF
JNIInvalidRefType = 0x0
JNILocalRefType = 0x1
JNIGlobalRefType = 0x2
JNIWeakGlobalRefType = 0x3
EOF
RUN

NAME=jni JNINativeInterface has NewStringUTF
FILE=bins/elf/jni/jniO0-arm64
CMDS=<<EOF
e asm.os=android
ts JNINativeInterface~NewStringUTF?
ts JNINativeInterface~GetVersion?
ts JNINativeInterface~FindClass?
ts JNINativeInterface~GetMethodID?
EOF
EXPECT=<<EOF
1
1
1
1
EOF
RUN

NAME=jni function signature arm64
FILE=bins/elf/jni/jniO0-arm64
CMDS=<<EOF
e asm.os=android
aaa
s sym.Java_JNIFoo_apiTest
afvt arg1 JNIEnv*
afvt arg2 jobject
pdf~apiTest
EOF
EXPECT=<<EOF
/ 80: sym.Java_JNIFoo_apiTest (JNIEnv*arg1, jobject arg2);
EOF
RUN

NAME=jni function signature x86
