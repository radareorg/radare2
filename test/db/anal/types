NAME=struct field type propagation from callee prototype
FILE=malloc://64
ARGS=-a x86 -b 64 -e types.fields=true
CMDS=<<EOF
wa mov rax, [rdi+8]
wa mov rdi, rax @ 4
wa call 0x20 @ 7
wa ret @ 0xc
wa ret @ 0x20
af @ 0x20
afn helper @ 0x20
af @ 0
afn caller @ 0
"td struct Ctx { char pad[8]; int field_8; };"
afs int helper(char *s) @ 0x20
afvt arg1 "struct Ctx *" @ 0
aei
aeim
aaft
tsc Ctx
EOF
EXPECT=<<EOF
struct Ctx {
  char pad[8];
  char *field_8;
};
EOF
RUN

