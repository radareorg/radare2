NAME=lwbrx byte-reverse emulation ppc-32
FILE=malloc://0x200
CMDS=<<EOF
e asm.arch=ppc
e asm.bits=32
e cfg.bigendian=true
wx deadbeef @ 0x100
wx 7c00642c @ 0
aei
aeim
ar r12=0x100
aes
ar r0
EOF
EXPECT=<<EOF
0xefbeadde
EOF
RUN

