NAME=load word and zero ppc-32
FILE=-
CMDS=<<EOF
e asm.arch=ppc
e asm.bits=32
e cfg.bigendian=true
(pi bytes;wx $0;pi 1;pie 1)
.(pi 8041fff8)
EOF
EXPECT=<<EOF
lwz r2, -8(r1)
0x00000000 -8,r1,+,[4],r2,=
EOF
RUN

