NAME=load doubleword byte-reverse indexed ppc-64
FILE=-
CMDS=<<EOF
e asm.arch=ppc
e asm.bits=64
e cfg.bigendian=true
(pi bytes;wx $0;pi 1;pie 1)
.(pi 7c006428)
EOF
EXPECT=<<EOF
ldbrx r0, 0, r12
0x00000000 r12,[1],8,1,r12,+,[1],<<,|,16,2,r12,+,[1],<<,|,24,3,r12,+,[1],<<,|,32,4,r12,+,[1],<<,|,40,5,r12,+,[1],<<,|,48,6,r12,+,[1],<<,|,56,7,r12,+,[1],<<,|,r0,=
EOF
RUN

