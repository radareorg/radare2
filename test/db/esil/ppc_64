NAME=ldbrx byte-reverse emulation ppc-64
FILE=malloc://0x200
CMDS=<<EOF
e asm.arch=ppc
e asm.bits=64
e cfg.bigendian=true
wx 0123456789abcdef @ 0x100
wx 7c006428 @ 0
aei
aeim
ar r12=0x100
aes
ar r0
EOF
EXPECT=<<EOF
0xefcdab8967452301
EOF
RUN
